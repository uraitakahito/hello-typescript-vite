{
  "name": "hello-typescript-vite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "html:lint": "markuplint index.html \"src/**/*.html\"",
    "clean": "npm run rmdir dist node_modules",
    "cleandep": "npm run rmdir node_modules",
    "rmdir": "node -e \"var fs = require('fs'); try{process.argv.slice(1).map((fpath) => fs.rmdirSync(fpath, { recursive: true }))}catch(err){console.log(err)}; process.exit(0);\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "markuplint": "^4.18.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.59.0",
    "vite": "8.0.9"
  },
  "overrides": {
    "minimatch": "^10.2.5"
  }
}
